{
  "name": "nuran-aac",
  "version": "3.1.0-local",
  "private": true,
  "type": "module",
  "description": "Nuran AAC PWA — runtime dependency-free; development tools are local only",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "node scripts/smoke-browser.mjs",
    "test:e2e:runner": "playwright test",
    "sync:ios": "node scripts/sync-ios.mjs",
    "verify:assets": "node scripts/verify-assets.mjs",
    "verify": "npm run verify:assets && npm test",
    "verify:all": "npm run verify && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "axe-core": "^4.10.3",
    "fake-indexeddb": "^6.2.2"
  }
}
